# ═══════════════════════════════════════════════════════════════════════════════
# MINIMUM — required to get started locally (everything else is optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Shared secret that guards mutating API endpoints (x-mergen-secret header).
# Any random string works. Generate one: openssl rand -hex 16
MERGEN_SECRET=mysecret

# ═══════════════════════════════════════════════════════════════════════════════
# FULL INTEGRATIONS — uncomment the sections you need
# Run `mergen-server doctor` at any time to check integration status.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Autonomous execution ──────────────────────────────────────────────────────
# MERGEN_AUTOPILOT=true            # execute fixes at ≥85% confidence (default: off)
# MERGEN_SHADOW_MODE=true          # diagnose but never execute — safe for first 30 days

# ── Slack (incident threads + PR comments) ────────────────────────────────────
# Create a bot at https://api.slack.com/apps → OAuth Scopes: chat:write, channels:read
# MERGEN_SLACK_BOT_TOKEN=xoxb-...
# MERGEN_SLACK_CHANNEL=#incidents
# MERGEN_SLACK_SIGNING_SECRET=...  # from Slack app → Basic Information → Signing Secret
# MERGEN_PR_COMMENTS=true          # post AI review comments on PRs (enables habituation tracking)

# ── PagerDuty (autonomous incident triage) ────────────────────────────────────
# Add a V3 webhook in PagerDuty: Service → Integrations → Webhooks
# URL: http://your-server:3000/webhooks/pagerduty
# MERGEN_PAGERDUTY_SECRET=...      # signing secret from your PagerDuty webhook config

# ── GitHub (intent archive + PR comments) ────────────────────────────────────
# Create a PAT at https://github.com/settings/tokens (scope: repo or admin:repo_hook)
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=...        # auto-set by: mergen-server connect github --repo owner/repo

# ── Datadog (blame attribution + trace fetch) ─────────────────────────────────
# Keys at: https://app.datadoghq.com/organization-settings/api-keys
# DD_API_KEY=...
# DD_APP_KEY=...
# DATADOG_SITE=datadoghq.com       # other options: datadoghq.eu, us3/us5/ap1.datadoghq.com

# ── Sentry ────────────────────────────────────────────────────────────────────
# MERGEN_SENTRY_SECRET=...         # HMAC secret from your Sentry webhook config

# ── Jira (one-click ticket creation) ─────────────────────────────────────────
# API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=...
# JIRA_BASE_URL=https://yourco.atlassian.net
# JIRA_PROJECT_KEY=ENG             # default project key; overridable per request

# ── Linear (one-click issue creation) ────────────────────────────────────────
# API key at: https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=...               # find in Linear → Settings → API; overridable per request

# ── Notifications ─────────────────────────────────────────────────────────────
# MERGEN_NTFY_TOPIC=mergen-alerts
# MERGEN_NTFY_URL=https://ntfy.sh
# MERGEN_NTFY_TOKEN=...            # only needed if your ntfy server requires auth
# MERGEN_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Docker monitoring ─────────────────────────────────────────────────────────
# MERGEN_DOCKER_MONITOR=true       # watch container health via Docker SDK
# MERGEN_DOCKER_LOGS=true          # stream stdout/stderr from all running containers

# ── Kubernetes ────────────────────────────────────────────────────────────────
# MERGEN_K8S_NAMESPACE=production  # poll K8s events for the given namespace

# ── Process auto-watch ────────────────────────────────────────────────────────
# MERGEN_AUTO_WATCH=false          # auto-watch local processes (default: true)
# MERGEN_AUTO_ATTACH_PORTS=3001,8080  # auto-attach process watcher to these ports

# ── Persistence (survive restarts) ───────────────────────────────────────────
# MERGEN_REDIS_URL=redis://localhost:6379

# ── Cloud / team mode ─────────────────────────────────────────────────────────
# MERGEN_CLOUD_MODE=true
# MERGEN_TLS_CERT=/path/to/cert.pem
# MERGEN_TLS_KEY=/path/to/key.pem
# MERGEN_ALLOWED_ORIGINS=https://app.example.com   # CORS allow-list
# MERGEN_BIND=0.0.0.0                              # default: 127.0.0.1 (local-only)

# ── Billing (LemonSqueezy) ────────────────────────────────────────────────────
# LS_API_KEY=...

# ── Telemetry (opt-in anonymous usage stats) ──────────────────────────────────
# MERGEN_TELEMETRY=1
