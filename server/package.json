{
  "name": "mergen-server",
  "version": "1.4.0",
  "description": "Mergen — AI operations layer for backend & infrastructure. Triages production incidents autonomously: OpenTelemetry + PagerDuty → causal analysis → executes fix at ≥85% confidence → validates → posts to Slack thread. MCP server for Claude Code, Cursor, Windsurf, VS Code.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mergen-server": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/__tests__/**",
    "sdk/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "incident-management",
    "autonomous-triage",
    "sre",
    "devops",
    "platform-engineering",
    "opentelemetry",
    "otlp",
    "pagerduty",
    "observability",
    "on-call",
    "mttr",
    "backend",
    "infrastructure",
    "claude",
    "cursor",
    "windsurf"
  ],
  "homepage": "https://github.com/omertt27/Mergen#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/omertt27/Mergen.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/omertt27/Mergen/issues"
  },
  "license": "MIT",
  "author": "omertt27",
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "mkdir -p sdk && cp ../sdk/node.js sdk/ && cp ../sdk/mergen-inject.js sdk/ && cp ../sdk/vite-plugin.ts sdk/ && cp ../sdk/webpack-plugin.js sdk/",
    "postpack": "rm -rf sdk",
    "build": "tsc && node scripts/build-cli.mjs",
    "build:fast": "node scripts/build-fast.mjs && node scripts/build-cli.mjs",
    "build:server": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:arch": "tsx src/scripts/check-arch.ts",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --config vitest.config.ci.ts",
    "test:ci:coverage": "vitest run --config vitest.config.ci.ts --coverage",
    "eval": "node ../scripts/eval.mjs",
    "eval:fast": "node ../scripts/eval.mjs --model gpt-4o-mini",
    "eval:dry": "node ../scripts/eval-dry.mjs",
    "eval:regression": "vitest run evals",
    "eval:update-baseline": "node ../scripts/update-eval-baseline.mjs",
    "eval:seed-corpus": "node ../scripts/seed-corpus.mjs"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "debug": "^4.4.0",
    "express": "^4.22.1",
    "fast-glob": "3.3.3",
    "helmet": "^8.0.0",
    "lru-cache": "11.3.5",
    "pino": "10.3.1",
    "source-map": "0.7.4",
    "sql.js": "^1.14.1",
    "stripe": "^22.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.11.5",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^4.1.9",
    "expect-type": "^0.19.0",
    "rolldown": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "^4.1.9"
  }
}
