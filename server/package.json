{
  "name": "mergen-server",
  "version": "1.4.0",
  "description": "Mergen MCP Server — local-first browser observability bridge for AI assistants (Cursor, Claude Desktop, Copilot, Continue, Windsurf, Cline). Streams console, network, WebSocket, React/Vue component trees from 127.0.0.1, returns causally-correlated Context Packs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mergen-server": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/__tests__/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "debugging",
    "browser",
    "console",
    "network",
    "dom",
    "local-first",
    "privacy",
    "cursor",
    "claude",
    "copilot",
    "windsurf",
    "continue"
  ],
  "homepage": "https://github.com/omertt27/Mergen#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/omertt27/Mergen.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/omertt27/Mergen/issues"
  },
  "license": "MIT",
  "author": "omertt27",
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/build-cli.mjs",
    "build:server": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "node ../scripts/eval.mjs",
    "eval:fast": "node ../scripts/eval.mjs --model gpt-4o-mini"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^4.22.1",
    "fast-glob": "3.3.3",
    "lru-cache": "11.3.5",
    "pino": "10.3.1",
    "source-map": "0.7.4",
    "sql.js": "^1.14.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.11.5",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "4.1.5",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "4.1.5"
  }
}
