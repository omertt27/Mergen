{
  "name": "mergen-server",
  "version": "1.0.0",
  "description": "Mergen MCP Server — local browser observability bridge",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/build-cli.mjs",
    "build:server": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "4.18.2",
    "fast-glob": "3.3.3",
    "lru-cache": "11.3.5",
    "pino": "10.3.1",
    "source-map": "0.7.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.11.5",
    "@vitest/coverage-v8": "4.1.5",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "4.1.5"
  }
}
