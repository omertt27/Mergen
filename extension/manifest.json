{
  "manifest_version": 3,
  "name": "Mergen — Browser Observability Bridge",
  "version": "1.0.0",
  "description": "Sends console logs and network events to the local Mergen MCP server for AI debugging.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:3001/*",
    "http://127.0.0.1:3002/*",
    "http://127.0.0.1:3003/*",
    "http://127.0.0.1:3004/*",
    "http://127.0.0.1:3005/*",
    "http://127.0.0.1:3006/*",
    "http://127.0.0.1:3007/*",
    "http://127.0.0.1:3008/*",
    "http://127.0.0.1:3009/*",
    "http://127.0.0.1:3010/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mergen",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}
