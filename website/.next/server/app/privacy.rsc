7:["$","section","Where data goes",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Where data goes"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"All captured events are sent via HTTP POST to a local server running on your machine at http://127.0.0.1:3000. This address is only reachable from processes running on your own computer — it is not accessible from the internet, your local network, or any other device."}],["$","ul",null,{"style":{"margin":"1rem 0","paddingLeft":"1.25rem","display":"flex","flexDirection":"column","gap":"0.4rem"},"children":[["$","li","No data is sent to Mergen servers",{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"No data is sent to Mergen servers"}],["$","li","No data is sent to any third-party analytics, logging, or monitoring service",{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"No data is sent to any third-party analytics, logging, or monitoring service"}],["$","li","No data is stored in a database or file that persists beyond the current debugging session (events are held in a 2,000-event in-memory ring buffer and optionally in a local ~/.mergen/ session file)",{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"No data is stored in a database or file that persists beyond the current debugging session (events are held in a 2,000-event in-memory ring buffer and optionally in a local ~/.mergen/ session file)"}],["$","li","The ~/.mergen/ directory is stored on your local machine only",{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"The ~/.mergen/ directory is stored on your local machine only"}]]}],"$undefined","$undefined"]}]
8:["$","section","Source map de-minification",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Source map de-minification"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"When source maps are present in your project, Mergen reads them from your local filesystem to convert minified stack frames into readable file paths and line numbers. Source maps are never uploaded or transmitted."}],"$undefined","$undefined","$undefined"]}]
9:["$","section","License and billing",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"License and billing"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"If you purchase a paid plan, your payment is processed by LemonSqueezy (our payment processor). Mergen receives only a license key and your email address to verify your subscription. Payment card details are handled entirely by LemonSqueezy and are never seen by Mergen. Your email is stored locally in ~/.mergen/license.json and is not shared with third parties."}],"$undefined","$undefined","$undefined"]}]
a:["$","section","Optional telemetry",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Optional telemetry"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"Mergen includes an opt-in telemetry system that sends anonymous usage statistics once every 24 hours: server version, Node.js version, plan tier, and aggregate tool call counts (e.g. \"analyze_runtime was called 3 times today\"). No event content, error messages, URLs, or stack traces are included. Telemetry can be disabled by setting MERGEN_TELEMETRY=false in your environment."}],"$undefined","$undefined","$undefined"]}]
b:["$","section","Calibration feedback",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Calibration feedback"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"When you rate a diagnosis (\"Did this fix it?\") in the dashboard, your feedback is stored locally in ~/.mergen/calibration.json. This file contains only the hypothesis tag, confidence score, and your verdict — never error messages, URLs, or any content from your application. Feedback is used locally to improve which detectors Mergen trusts for your specific codebase."}],"$undefined","$undefined","$undefined"]}]
c:["$","section","Data retention and deletion",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Data retention and deletion"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"To delete all Mergen data, run:"}],"$undefined",["$","pre",null,{"style":{"margin":"1rem 0","padding":"0.75rem 1rem","background":"var(--gray-800)","borderRadius":4,"fontFamily":"var(--font-geist-mono)","fontSize":"0.8rem","color":"var(--accent-text)","overflowX":"auto"},"children":"rm -rf ~/.mergen/"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7,"marginTop":"0.75rem"},"children":"This removes your license key, session history, calibration feedback, and all local configuration. The browser extension stores no data of its own — it only forwards events to the local server."}]]}]
d:["$","section","Children",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Children"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"Mergen is a developer tool intended for professional use. It is not directed at children under 13 and does not knowingly collect information from children."}],"$undefined","$undefined","$undefined"]}]
e:["$","section","Changes to this policy",{"style":{"padding":0,"borderTop":"1px solid var(--gray-800)"},"children":[["$","h2",null,{"style":{"fontSize":"0.9rem","fontWeight":700,"marginTop":"2rem","marginBottom":"1rem","color":"var(--white)"},"children":"Changes to this policy"}],["$","p",null,{"style":{"color":"var(--gray-400)","fontSize":"0.875rem","lineHeight":1.7},"children":"If we make material changes to this privacy policy, we will update this page and increment the version number below. Continued use of Mergen after a policy update constitutes acceptance of the revised policy."}],"$undefined","$undefined","$undefined"]}]
