17:{"metadata":[["$","title","0",{"children":"Privacy Policy — Mergen"}],["$","meta","1",{"name":"description","content":"Mergen privacy policy. All data stays on 127.0.0.1 — nothing leaves your machine."}],["$","meta","2",{"name":"robots","content":"index, follow"}],["$","meta","3",{"property":"og:title","content":"Mergen — Operational Memory for AI Agents"}],["$","meta","4",{"property":"og:description","content":"Mergen compresses raw production telemetry into structured machine context, encodes your team's override decisions as enforceable policy, and gives AI coding agents the operational facts they need to act safely in production."}],["$","meta","5",{"property":"og:url","content":"https://mergen.dev"}],["$","meta","6",{"property":"og:site_name","content":"Mergen"}],["$","meta","7",{"property":"og:image:alt","content":"Mergen — Operational Memory for AI Agents"}],["$","meta","8",{"property":"og:image:type","content":"image/png"}],["$","meta","9",{"property":"og:image","content":"https://mergen.dev/opengraph-image?f9386f68cdfbc715"}],["$","meta","10",{"property":"og:image:width","content":"1200"}],["$","meta","11",{"property":"og:image:height","content":"630"}],["$","meta","12",{"property":"og:type","content":"website"}],["$","meta","13",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","14",{"name":"twitter:title","content":"Mergen — Operational Memory for AI Agents"}],["$","meta","15",{"name":"twitter:description","content":"Mergen compresses raw production telemetry into structured machine context, encodes your team's override decisions as enforceable policy, and gives AI coding agents the operational facts they need to act safely in production."}],["$","meta","16",{"name":"twitter:image","content":"https://mergen.dev/og-image.png"}]],"error":null,"digest":"$undefined"}
